# Gaming Performance Init Script
on property:sys.boot_completed=1
    # CPU performance
    write /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor "performance"
    write /sys/devices/system/cpu/cpu4/cpufreq/scaling_governor "performance"
    write /sys/devices/system/cpu/cpu6/cpufreq/scaling_governor "performance"
    
    # GPU performance
    write /proc/gpufreq/gpufreq_power_mode "performance"
    
    # I/O performance
    write /sys/block/mmcblk0/queue/scheduler "kyber"
    write /sys/block/mmcblk0/queue/read_ahead_kb 256
    
    # VM tuning
    write /proc/sys/vm/swappiness 100
    write /proc/sys/vm/vfs_cache_pressure 20
    write /proc/sys/vm/dirty_ratio 20
    write /proc/sys/vm/dirty_background_ratio 5

on property:sys.boot_completed=1
    start gaming-tweaks

service gaming-tweaks /system/bin/gaming_tweaks
    class late_start
    user root
    group root
    disabled
    oneshot